# ================================
# BacPrep MR — Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs
# ================================

# === FIREBASE (Console Firebase > Paramètres du projet) ===
FIREBASE_API_KEY=ta_cle_api_firebase
FIREBASE_AUTH_DOMAIN=ton-projet.firebaseapp.com
FIREBASE_PROJECT_ID=ton-projet-id
FIREBASE_STORAGE_BUCKET=ton-projet.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef

# === FIREBASE ADMIN (Console Firebase > Service accounts) ===
# Colle ici le contenu du fichier JSON de compte de service (en une seule ligne)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# === ANTHROPIC (platform.anthropic.com) ===
ANTHROPIC_API_KEY=sk-ant-...

# === SECURITE ===
JWT_SECRET=une_longue_chaine_aleatoire_tres_secrete_ici
SETUP_SECRET=secret_pour_creer_compte_demo

# === APP ===
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000
